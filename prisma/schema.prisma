generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["books_api"]
}

model Publisher {
  id          Int      @id @default(autoincrement())
  name        String
  country     String
  foundedYear Int
  website     String
  createdAt   DateTime @default(now())

  // One-to-many: One publisher has many books
  books       Book[]

  @@map("publishers")
  @@schema("books_api")
}

model Genre {
  id    Int    @id @default(autoincrement())
  name  String @unique

  // Many-to-many: A genre can have many books
  books Book[] @relation("BookToGenre")

  @@map("genres")
  @@schema("books_api")
}

model Review {
  id        Int      @id @default(autoincrement())
  bookId    Int      @map("book_id")
  userName  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  // Many-to-one: Many reviews belong to one book
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("reviews")
  @@schema("books_api")
}

model Author {
  id          Int      @id @default(autoincrement())
  firstName   String   @db.VarChar(100)
  lastName    String   @db.VarChar(100)
  birthYear   Int
  nationality String
  biography   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // One-to-many: One author can write many books
  books       Book[]

  @@map("authors")
  @@schema("books_api")
}

model Book {
  id            Int      @id @default(autoincrement())
  title         String   @db.VarChar(255)
  isbn          String   @unique
  publishedYear Int
  pageCount     Int
  language      String
  description   String
  coverImage    String
  authorId      Int      @map("author_id")
  publisherId   Int      @map("publisher_id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  author        Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  publisher     Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  reviews       Review[]
  genres        Genre[]   @relation("BookToGenre")

  @@map("books")
  @@schema("books_api")
}