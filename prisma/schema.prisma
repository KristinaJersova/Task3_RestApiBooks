generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["books_api"]
}

model Book {
  id            Int      @id @default(autoincrement())
  title         String   @db.VarChar(255)
  isbn          String
  publishedYear Int
  pageCount     Int
  language      String
  description   String
  coverImage    String
  author_id     Int
  publisherId   Int
  genres        Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  books Book[]

  @@map("books")
  @@schema("books_api")
}

model Author {
  id          Int      @id @default(autoincrement())
  firstName   String   @db.VarChar(100)
  lastName    String   @db.VarChar(100)
  birthYear   Int      
  nationality String 
  biography   String   
  createdAt   DateTime @default(now())

  books Book[]

  @@map("authors")
  @@schema("books_api")
}

model Publisher {
  id          Int      @id @default(autoincrement())
  name        String
  country     String
  foundedYear Int
  website     String
  createdAt   DateTime @default(now())

  books Book[]

  @@map("puplisher")
  @@schema("books_api")
}

model Genre {
  id    Int
  name  String

  books Book[]

  @@map("puplisher")
  @@schema("books_api")
}

model Review {
    id:         Int
    bookId:     Int @relation(fields: [bookId], references: [id], onDelete: Cascade)
    userName:   String
    rating:     Int
    comment:    String
    createdAt:  DateTime @default(now())
    
    books Book[]

  @@map("puplisher")
  @@schema("books_api")
}